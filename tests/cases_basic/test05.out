10 PRINT "Basic program with auto line nums"
20 DATA 1,2,3
30 PRINT "Line with LABEL1"
40 PRINT "Line with LABEL2"
50 PRINT "Line with LABEL3"
60 PRINT "Line with LABEL4"
70 RESTORE 20
80 GOTO 30
90 GOSUB 40
100 ON I% GOSUB 30,40
110 ON I% GOTO 50,60
120 IF I%=1 THEN GOTO 30 ELSE  GOSUB 60
130 IF A%=2 THEN PRINT "2"   ELSE  GOSUB 60
140 IF A%=3 THEN GOTO 30 ELSE  PRINT "3"
150 IF I%=1 THEN PRINT " GOTO Label1"   ELSE  GOSUB 60
160 IF I%=1 THEN GOTO 30 ELSE  PRINT " GOSUB LABEL4"
170 IF I%=1 THEN PRINT " GOTO Label1"   ELSE  PRINT " GOSUB LABEL4"
180 IF I%=1 THEN PRINT " GOTO Label1   ELSE  GOSUB LABEL4"
190 ? "IF I%=1 THEN GOTO Label1   ELSE  GOSUB LABEL4"
200 GOTO 220
210 BEEP
220 END
