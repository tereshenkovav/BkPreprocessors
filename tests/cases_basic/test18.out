1 PRINT "Basic program with auto line nums"
2 DATA 1,2,3
3 PRINT "Line with LABEL1"
4 PRINT "Line with LABEL2"
5 PRINT "Line with LABEL3"
6 PRINT "Line with LABEL4"
7 RESTORE 2
8 GOTO 3
9 GOSUB 4
10 ON I% GOSUB 3,4
11 ON I% GOTO 5,6
12 IF I%=1 THEN GOTO 3 ELSE  GOSUB 6
13 IF A%=2 THEN PRINT "2"   ELSE  GOSUB 6
14 IF A%=3 THEN GOTO 3 ELSE  PRINT "3"
15 IF I%=1 THEN PRINT " GOTO Label1"   ELSE  GOSUB 6
16 IF I%=1 THEN GOTO 3 ELSE  PRINT " GOSUB LABEL4"
17 IF I%=1 THEN PRINT " GOTO Label1"   ELSE  PRINT " GOSUB LABEL4"
18 IF I%=1 THEN PRINT " GOTO Label1   ELSE  GOSUB LABEL4"
19 ? "IF I%=1 THEN GOTO Label1   ELSE  GOSUB LABEL4"
20 GOTO 22
21 BEEP
22 END
